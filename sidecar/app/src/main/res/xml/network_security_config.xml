<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Permit cleartext HTTP on LAN for coordinator + inference communication.
         Pairing + TLS (issue #165) will narrow this to TLS-only post-pairing. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
